    "2_INPUT_NUMERIC_FAIL": {
      "description": "Input data numerik - Hasil FAIL (melebihi threshold FDA)",
      "method": "POST",
      "endpoint": "/test-sessions/1/input-numeric",
      "request_body": {
        "test_parameter_id": 1,
        "measured_value": 45.5,
        "notes": "Sampel dengan migrasi tinggi di simulan asam"
      },
      "expected_response": {
        "success": true,
        "data": {
          "id": 124,
          "test_session_id": 1,
          "test_parameter_id": 1,
          "measured_value": "45.5000",
          "unit": "mg/dm2",
          "applied_standard_id": 2,
          "standard_min_value": null,
          "standard_max_value": "10.00000000",
          "result_status": "FAIL",
          "deviation_percentage": "355.0000",
