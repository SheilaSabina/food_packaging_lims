    },

    "3_INPUT_NUMERIC_INCONCLUSIVE": {
      "description": "Input data numerik - Hasil INCONCLUSIVE (tidak ada standar untuk perbandingan)",
      "method": "POST",
      "endpoint": "/test-sessions/1/input-numeric",
      "request_body": {
        "test_parameter_id": 5,
        "measured_value": 7.2,
        "notes": "pH pengujian dalam simulan netral"
      },
      "expected_response": {
        "success": true,
        "data": {
          "measured_value": "7.2000",
          "result_status": "INCONCLUSIVE",
          "data_status": "Draft",
          "calculation_details": {
            "warning": "Tidak ada standar aktif untuk perbandingan otomatis"
          }
        },
        "messages": [
          "✓ Nilai numerik valid: 7.2000",
          "⚠️ Tidak ada standar aktif untuk perbandingan otomatis",
          "✓ Data hasil uji tersimpan"
        ]
      }
    },

    "4_INPUT_NUMERIC_VALIDATION_ERROR": {
      "description": "Input data numerik - ERROR (nilai tidak valid)",
      "method": "POST",
      "endpoint": "/test-sessions/1/input-numeric",
      "request_body": {
        "test_parameter_id": 1,
        "measured_value": "abc123",
        "notes": ""
      },
      "expected_response": {
        "success": false,
        "data": null,
        "messages": [
          "Nilai numerik tidak valid. Presisi maksimal 4 desimal."
        ]
      }
    },

    "5_UPLOAD_EVIDENCE": {
      "description": "Upload bukti foto untuk hasil uji",
      "method": "POST",
      "endpoint": "/test-results/123/upload-evidence",
      "request_body_formdata": {
        "file": "(binary JPG/PNG/PDF file, max 10MB)",
        "evidence_type": "Test Photo",
        "description": "Foto hasil pengujian migrasi di spektrofotometer"
      },
      "expected_response": {
        "success": true,
        "data": {
          "id": 999,
          "test_result_id": 123,
          "test_session_id": 1,
          "file_name": "1713245680_abc123def456.jpg",
          "file_path": "test-evidences/1/1713245680_abc123def456.jpg",
          "file_type": "image/jpeg",
          "file_size": 524288,
          "evidence_type": "Test Photo",
          "description": "Foto hasil pengujian migrasi di spektrofotometer",
          "uploaded_by": "Budi Santoso",
          "uploaded_at": "2026-04-16T10:45:30.000000Z",
          "is_verified": false
        },
        "message": "Bukti pengujian berhasil diunggah"
      }
    },

