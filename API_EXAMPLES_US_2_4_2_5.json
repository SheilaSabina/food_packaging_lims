  "NOTES": {
    "precision": "Semua nilai decimal disimpan dengan presisi 8 desimal (decimal:8)",
    "status_values": [
      "PASS - Nilai memenuhi semua standar aktif",
      "FAIL - Ada minimal 1 standar yang tidak terpenuhi",
      "INCONCLUSIVE - Tidak ada standar aktif untuk perbandingan"
    ],
    "data_status_values": [
      "Alat Siap - Equipment siap pakai (terkalibrasi)",
      "In-Progress - Pengujian sedang berlangsung",
      "Draft - Data tersimpan, menunggu verifikasi",
      "Verified - Supervisor approve, data terkunci"
    ],
    "file_upload_limits": {
      "max_size_mb": 10,
      "allowed_types": [
        "image/jpeg",
        "image/png",
        "image/gif",
        "application/pdf"
      ]
    }
  }
