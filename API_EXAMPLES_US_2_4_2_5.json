    "7_VERIFY_APPROVE": {
      "description": "Supervisor approve semua hasil uji (Verifikasi)",
      "method": "POST",
      "endpoint": "/test-sessions/1/verify",
      "request_body": {
        "action": "approve"
      },
      "expected_response": {
        "success": true,
        "message": "Semua hasil uji diverifikasi",
        "summary": {
          "total_results": 3,
          "passed_results": 2,
          "failed_results": 1,
          "overall_status": "FAIL"
        }
      }
    },

    "8_VERIFY_REJECT": {
      "description": "Supervisor reject hasil uji dengan alasan",
      "method": "POST",
      "endpoint": "/test-sessions/1/verify",
      "request_body": {
        "action": "reject",
        "rejection_reason": "Foto bukti untuk parameter BPA tidak jelas, perlu diulang pengujian dan dokumentasi"
      },
      "expected_response": {
        "success": true,
        "message": "Hasil uji ditolak. Teknisi dapat memperbaiki data.",
        "rejection_reason": "Foto bukti untuk parameter BPA tidak jelas, perlu diulang pengujian dan dokumentasi"
      }
    },

